    "definitions": {
        "api.VerifyBuildStatusRequest": {
            "type": "object",
            "required": [
                "image_id",
                "status"
            ],
            "properties": {
                "external_ref": {
                    "type": "string"
                },
                "intent_id": {
                    "type": "string"
                },
                "image_id": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "pipeline_id": {
                    "type": "string"
                },
                "status": {
