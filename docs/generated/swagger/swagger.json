                }
            }
        },
        "api.VerifyBuildStepRequest": {
            "type": "object",
            "required": [
                "image_id",
                "status",
                "task_name"
            ],
            "properties": {
                "end_time": {
                    "type": "string"
                },
                "image_id": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "pipeline_id": {
                    "type": "string"
                },
                "start_time": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/definitions/model.StepStatus"
                },
                "task_name": {
                    "type": "string"
                },
                "task_run": {
                    "type": "string"
                }
            }
        },
        "api.VerifyReleaseStatusRequest": {
            "type": "object",
